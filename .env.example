APP_NAME="Kaggle EAC ASR"
ENVIRONMENT=development
DATABASE_URL=sqlite:///./outputs/local_data/afrivoice.db
UPLOAD_DIR=outputs/local_data/uploads
MODEL_NAME=mock-afrivoice-asr-v0
MODEL_RUNTIME=mock
ASR_ADAPTER=mock
CONFIDENCE_THRESHOLD=0.65
KAGGLE_DATASET_ID=digitalumuganda/anv-test-data-nt
LOCAL_KAGGLE_DATASET_PATH="/Users/michaelprempeh/Downloads/anv-test-data-nt (2)"
HF_DATASETS=DigitalUmuganda/Afrivoice_Swahili,MCAA1-MSU/anv_data_ke,DigitalUmuganda/Afrivoice
TTS_BACKEND=local_wave
TTS_OUTPUT_DIR=outputs/local_data/tts

# Change this in every non-local environment.
AUTH_SECRET=replace-with-a-long-random-production-secret

# local | s3 | gcs | supabase
STORAGE_BACKEND=local
CLOUD_BUCKET=
CLOUD_PREFIX=afrivoice/audio

# local | celery
QUEUE_BACKEND=local
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
